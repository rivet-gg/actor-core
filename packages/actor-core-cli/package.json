{
  "name": "@actor-core/cli",
  "description": "All purpose CLI for Actor Core",
  "version": "0.3.0",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "package.json",
    "bin.js"
  ],
  "type": "module",
  "bin": "bin.js",
  "sideEffects": false,
  "preferGlobal": true,
