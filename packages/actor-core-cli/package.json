    "bundle-require": "^5.1.0",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-link": "^4.1.0",
    "ink-spinner": "^5.0.0",
    "joycon": "^3.1.1",
    "react": "^18.3",
    "strip-ansi": "^7.1.0",
    "zx": "^8.3.2"
  },
  "devDependencies": {
    "@types/react": "^18.3"
  }
}
